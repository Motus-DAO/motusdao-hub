generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@map("contact_messages")
}

model Course {
  id               String            @id
  title            String
  slug             String            @unique
  summary          String
  description      String?
  imageUrl         String?
  isPublished      Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  category         String?           @default("General")
  difficulty       CourseDifficulty? @default(beginner)
  instructor       String?           @default("MotusDAO")
  instructorBio    String?
  instructorImage  String?
  instructorTitle  String?
  lastUpdated      String?
  learningOutcomes Json?             @db.JsonB
  rating           Float?            @default(0)
  reviewCount      Int?              @default(0)
  enrollments      Enrollment[]
  orderItems       OrderItem[]
  reviews          Review[]
  modules          Module[]
  priceAmount      Decimal?          @db.Decimal(12, 2)
  priceCurrency    String            @default("MXN")
  isFree           Boolean           @default(true)

  @@map("courses")
}

model Module {
  id        String   @id
  courseId  String
  title     String
  summary   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons   Lesson[]

  @@map("modules")
}

model Enrollment {
  id        String   @id
  userId    String
  courseId  String
  progress  Int      @default(0)
  completed Boolean  @default(false)
  purchasedAt DateTime?
  accessExpiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
  paymentLogs PaymentLog[]
  lessonProgress LessonProgress[]
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  content   String
  mood      String?
  tags      Json?    @db.JsonB
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("journal_entries")
}

model ClinicalAccessLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  targetUserId String?
  action       String
  resource     ClinicalResource
  resourceId   String?
  reason       String?
  metadata     Json?    @db.JsonB
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("clinical_access_actor", fields: [actorUserId], references: [id])
  target       User?    @relation("clinical_access_target", fields: [targetUserId], references: [id])

  @@index([targetUserId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([resource, resourceId])
  @@map("clinical_access_logs")
}

model Lesson {
  id            String   @id
  title         String
  slug          String
  contentMDX    String?
  order         Int      @default(0)
  duration      Int?
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  moduleId      String?
  summary       String?
  isFreePreview Boolean  @default(false)
  pdfResources  Json?    @db.JsonB
  videoUrl      String?
  module        Module?  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  lessonProgress LessonProgress[]

  @@map("lessons")
}

model LessonProgress {
  id           String     @id @default(cuid())
  userId       String
  lessonId     String
  enrollmentId String?
  completed    Boolean    @default(true)
  completedAt  DateTime?
  lastPosition Int?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson       Lesson     @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  enrollment   Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([userId, lessonId])
  @@map("lesson_progress")
}

model Match {
  id        String      @id @default(cuid())
  userId    String
  psmId     String
  status    MatchStatus @default(active)
  matchedAt DateTime    @default(now())
  endedAt   DateTime?
  reason    String?
  source    MatchSource @default(automatic)
  score     Float?
  scoreBreakdown Json?  @db.JsonB
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  psm       User        @relation("matches_psmIdTousers", fields: [psmId], references: [id], onDelete: Cascade)
  user      User        @relation("matches_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)
  criteria  MatchCriterion[]
  sessions  Session[]

  @@index([psmId, status])
  @@index([userId, status])
  @@map("matches")
}

model MatchCriterion {
  id        String   @id @default(cuid())
  matchId   String
  criterion String
  score     Float
  details   Json?    @db.JsonB
  createdAt DateTime @default(now())
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@map("match_criteria")
}

model PatientProfile {
  id                           String       @id @default(cuid())
  userId                       String       @unique
  tipoAtencion                 String
  problematica                 String
  preferenciaAsignacion        String
  clinicalConcern              Json         @default("[]") @db.JsonB
  urgencyLevel                 UrgencyLevel @default(medium)
  preferredModality            Modality     @default(video)
  preferredTherapyStyle        Json         @default("[]") @db.JsonB
  languages                    Json         @default("[\"es\"]") @db.JsonB
  timezone                     String?
  availability                 Json         @default("{}") @db.JsonB
  budgetMin                    Int?
  budgetMax                    Int?
  paymentPreference            String?
  therapistGenderPreference    String?
  priorTherapyExperience       Boolean?
  medicationOrDiagnosisContext String?
  riskFlags                    Json         @default("[]") @db.JsonB
  createdAt                    DateTime     @default(now())
  updatedAt                    DateTime     @updatedAt
  user                         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("patient_profiles")
}

model PaymentLog {
  id                 String             @id @default(cuid())
  fromUserId         String
  toUserId           String?
  destination        PaymentDestination
  destinationAddress String
  amount             String
  currency           String
  transactionHash    String             @unique
  explorerUrl        String?
  notes              String?
  orderId            String?
  paymentId          String?
  sessionId          String?
  enrollmentId       String?
  createdAt          DateTime           @default(now())
  fromUser           User               @relation("payment_logs_fromUserIdTousers", fields: [fromUserId], references: [id], onDelete: Cascade)
  enrollment         Enrollment?        @relation(fields: [enrollmentId], references: [id])
  order              Order?             @relation(fields: [orderId], references: [id])
  payment            Payment?           @relation(fields: [paymentId], references: [id])
  session            Session?           @relation(fields: [sessionId], references: [id])
  toUser             User?              @relation("payment_logs_toUserIdTousers", fields: [toUserId], references: [id])

  @@index([destination])
  @@index([fromUserId, createdAt])
  @@index([toUserId, createdAt])
  @@index([orderId])
  @@index([paymentId])
  @@index([sessionId])
  @@map("payment_logs")
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  status        OrderStatus @default(pending)
  subtotalAmount Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount   Decimal     @default(0) @db.Decimal(12, 2)
  currency      String      @default("MXN")
  notes         String?
  metadata      Json?       @db.JsonB
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  completedAt   DateTime?
  cancelledAt   DateTime?
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  payments      Payment[]
  paymentLogs   PaymentLog[]

  @@index([userId, status])
  @@map("orders")
}

model OrderItem {
  id           String        @id @default(cuid())
  orderId      String
  type         OrderItemType
  description  String
  quantity     Int           @default(1)
  unitAmount   Decimal       @db.Decimal(12, 2)
  totalAmount  Decimal       @db.Decimal(12, 2)
  currency     String        @default("MXN")
  sessionId    String?
  courseId     String?
  enrollmentId String?
  metadata     Json?         @db.JsonB
  createdAt    DateTime      @default(now())
  course       Course?       @relation(fields: [courseId], references: [id])
  enrollment   Enrollment?   @relation(fields: [enrollmentId], references: [id])
  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  session      Session?      @relation(fields: [sessionId], references: [id])

  @@index([orderId])
  @@index([sessionId])
  @@index([courseId])
  @@map("order_items")
}

model Payment {
  id                 String        @id @default(cuid())
  orderId            String
  userId             String
  status             PaymentStatus @default(pending)
  provider           PaymentProvider @default(onchain)
  amount             Decimal       @db.Decimal(12, 2)
  currency           String
  destination        PaymentDestination
  destinationAddress String
  transactionHash    String?       @unique
  explorerUrl        String?
  metadata           Json?         @db.JsonB
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  confirmedAt        DateTime?
  failedAt           DateTime?
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs               PaymentLog[]

  @@index([orderId])
  @@index([userId, status])
  @@map("payments")
}

model PaymentPreference {
  id                 String             @id @default(cuid())
  userId             String             @unique
  defaultDestination PaymentDestination @default(own_wallet)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_preferences")
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  nombre          String
  apellido        String
  telefono        String
  fechaNacimiento DateTime
  ciudad          String
  pais            String
  avatarUrl         String?
  avatarStoragePath String?
  bio               String?
  language        String   @default("es")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("profiles")
}

model PSMProfile {
  id                     String             @id @default(cuid())
  userId                 String             @unique
  cedulaProfesional      String
  cedulaDocumentPath     String?
  tituloDocumentPath     String?
  formacionAcademica     String
  experienciaAnios       Int
  biografia              String?
  professionalNarrative  String?
  especialidades         Json               @db.JsonB
  verificationStatus     VerificationStatus @default(pending)
  isAcceptingPatients    Boolean            @default(false)
  maxActivePatients      Int                @default(10)
  therapyStyles          Json               @default("[]") @db.JsonB
  languages              Json               @default("[\"es\"]") @db.JsonB
  licensedCountries      Json               @default("[]") @db.JsonB
  licensedRegions        Json               @default("[]") @db.JsonB
  timezone               String?
  availability           Json               @default("{}") @db.JsonB
  modalities             Json               @default("[\"video\"]") @db.JsonB
  sessionPrice           Int?
  currency               String             @default("MXN")
  acceptsSlidingScale    Boolean            @default(false)
  worksWithUrgencyLevels Json               @default("[\"low\",\"medium\"]") @db.JsonB
  exclusionCriteria      Json               @default("[]") @db.JsonB
  adminReviewNotes       String?
  verifiedAt             DateTime?
  verifiedByUserId       String?
  rejectedAt             DateTime?
  suspendedAt            DateTime?
  participaSupervision   Boolean            @default(false)
  participaCursos        Boolean            @default(false)
  participaInvestigacion Boolean            @default(false)
  participaComunidad     Boolean            @default(false)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("psm_profiles")
}

model ConsentRecord {
  id                        String   @id @default(cuid())
  userId                    String
  consentToTerms            Boolean  @default(false)
  consentToPrivacy          Boolean  @default(false)
  consentToAIProcessing     Boolean  @default(false)
  consentToShareWithPSM     Boolean  @default(false)
  consentToClinicalMatching Boolean  @default(false)
  source                    String   @default("onboarding")
  policyVersion             String   @default("v1")
  locale                    String   @default("es")
  scope                     Json     @default("{}") @db.JsonB
  acceptedAt                DateTime @default(now())
  revokedAt                 DateTime?
  revocationReason          String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, acceptedAt])
  @@map("consent_records")
}

model CrisisEvent {
  id          String      @id @default(cuid())
  userId      String
  source      String      @default("intake")
  severity    CrisisSeverity @default(possible)
  status      CrisisStatus   @default(open)
  summary     String?
  metadata    Json?       @db.JsonB
  resolvedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("crisis_events")
}

model Session {
  id           String        @id @default(cuid())
  userId       String
  psmId        String
  matchId      String?
  status       SessionStatus @default(requested)
  mode         SessionMode   @default(video_external)
  externalUrl  String
  requestedAt  DateTime      @default(now())
  scheduledStart DateTime?
  scheduledEnd DateTime?
  timezone     String?
  durationMinutes Int?
  acceptedAt   DateTime?
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  cancelReason String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  match        Match?        @relation(fields: [matchId], references: [id])
  orderItems   OrderItem[]
  paymentLogs  PaymentLog[]
  reviews      Review[]
  psm          User          @relation("sessions_psmIdTousers", fields: [psmId], references: [id], onDelete: Cascade)
  user         User          @relation("sessions_userIdTousers", fields: [userId], references: [id], onDelete: Cascade)

  @@index([psmId, status])
  @@index([userId, status])
  @@index([scheduledStart, scheduledEnd])
  @@map("sessions")
}

model ProviderAvailabilitySlot {
  id          String   @id @default(cuid())
  psmId       String
  startsAt    DateTime
  endsAt      DateTime
  timezone    String?
  isRecurring Boolean  @default(false)
  recurrenceRule String?
  isAvailable Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  psm         User     @relation(fields: [psmId], references: [id], onDelete: Cascade)

  @@index([psmId, startsAt])
  @@map("provider_availability_slots")
}

model Review {
  id        String   @id @default(cuid())
  authorId  String
  psmId     String?
  courseId  String?
  sessionId String?
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("reviews_author", fields: [authorId], references: [id], onDelete: Cascade)
  psm       User?    @relation("reviews_psm", fields: [psmId], references: [id])
  course    Course?  @relation(fields: [courseId], references: [id])
  session   Session? @relation(fields: [sessionId], references: [id])

  @@index([psmId])
  @@index([courseId])
  @@map("reviews")
}

model AuthNonce {
  id        String   @id @default(cuid())
  address   String
  nonce     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([address])
  @@map("auth_nonces")
}

model User {
  id                    String             @id @default(cuid())
  role                  Role               @default(usuario)
  email                 String             @unique
  privyId               String?            @unique
  authProvider          AuthProvider?
  authProviderId        String?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  eoaAddress            String             @unique
  smartWalletAddress    String?            @unique
  registrationCompleted Boolean            @default(false)
  onboardingStatus      OnboardingStatus   @default(started)
  intakeSource          IntakeSource       @default(manual)
  motusName             String?
  mnsTxHash             String?
  mnsRegisteredAt       DateTime?
  profileNftTxHash      String?
  profileNftTokenURI    String?
  deletedAt             DateTime?
  restoredAt            DateTime?
  availabilitySlots     ProviderAvailabilitySlot[]
  clinicalAccessAsActor ClinicalAccessLog[] @relation("clinical_access_actor")
  clinicalAccessAsTarget ClinicalAccessLog[] @relation("clinical_access_target")
  consentRecords        ConsentRecord[]
  contactMessages       ContactMessage[]
  crisisEvents          CrisisEvent[]
  enrollments           Enrollment[]
  lessonProgress        LessonProgress[]
  journalEntries        JournalEntry[]
  psmMatches            Match[]            @relation("matches_psmIdTousers")
  userMatches           Match[]            @relation("matches_userIdTousers")
  patient               PatientProfile?
  paymentsSent          PaymentLog[]       @relation("payment_logs_fromUserIdTousers")
  paymentsReceived      PaymentLog[]       @relation("payment_logs_toUserIdTousers")
  orders                Order[]
  payments              Payment[]
  paymentPreference     PaymentPreference?
  profile               Profile?
  psm                   PSMProfile?
  reviewsAuthored       Review[]           @relation("reviews_author")
  reviewsReceivedAsPSM  Review[]           @relation("reviews_psm")
  sessionsAsPSM         Session[]          @relation("sessions_psmIdTousers")
  sessionsAsUser        Session[]          @relation("sessions_userIdTousers")

  @@map("users")
}

enum AuthProvider {
  waap
  privy
  external
}

enum MatchStatus {
  active
  paused
  ended
}

enum MatchSource {
  automatic
  admin
  manual
}

enum ClinicalResource {
  profile
  patient_profile
  psm_profile
  journal_entry
  match
  session
  document
  payment
  crisis_event
}

enum CrisisSeverity {
  possible
  high
  imminent
}

enum CrisisStatus {
  open
  reviewed
  escalated
  resolved
  dismissed
}

enum OrderStatus {
  pending
  paid
  fulfilled
  cancelled
  refunded
}

enum OrderItemType {
  session
  course
  subscription
  donation
  provider_payout
  dao_treasury
}

enum PaymentStatus {
  pending
  confirmed
  failed
  refunded
}

enum PaymentProvider {
  onchain
  transak
  manual
}

enum PaymentDestination {
  own_wallet
  matched_psm
  dao_treasury
}

enum Role {
  usuario
  psm
  admin
}

enum OnboardingStatus {
  started
  wallet_connected
  profile_incomplete
  profile_complete
  pending_verification
  active
  blocked
}

enum IntakeSource {
  manual
  ai_assisted
  hybrid
}

enum VerificationStatus {
  pending
  approved
  rejected
  suspended
}

enum UrgencyLevel {
  low
  medium
  high
  crisis
}

enum Modality {
  video
  chat
  in_person
  hybrid
}

enum SessionMode {
  video_external
}

enum SessionStatus {
  requested
  accepted
  completed
  cancelled
}

enum CourseDifficulty {
  beginner
  intermediate
  advanced
}
